# ─── AITranscription Feature Configuration ─────────────────────────────────
#
# Copy this file to .env or .env.local and fill in your values.
# See docs/AITRANSCRIPTION_SETUP.md for detailed instructions.

# Feature Flag
# Set to "true" to enable the AITranscription transcription feature.
# When "false", all /api/transcriptions endpoints return 503.
HEIDI_ENABLED=false

# AITranscription Health API Base URL
# Region-specific. Choose the correct one for your data residency:
#   US: https://api.us.heidihealth.com
#   AU: https://api.au.heidihealth.com
#   EU: https://api.eu.heidihealth.com
#   UK: https://api.uk.heidihealth.com
HEIDI_API_BASE_URL=

# AITranscription Health API Key
# Generate from AITranscription dashboard: Settings > API Access
# NEVER commit this value to source control.
HEIDI_API_KEY=

# ─── Optional: Frontend WebSocket ──────────────────────────────────────────
#
# The frontend derives the WebSocket URL from VITE_API_URL.
# If not set, it falls back to window.location.host.
# VITE_API_URL=http://localhost:3000
